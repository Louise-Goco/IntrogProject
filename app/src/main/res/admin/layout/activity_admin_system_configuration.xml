<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Configuration"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delivery Fee Structure"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>
        
    <EditText
        android:id="@+id/etBaseDeliveryFee"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Base Delivery Fee"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:backgroundTint="#888888"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service Charge Rate (%)"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etServiceCharge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Service Charge Rate"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:backgroundTint="#888888"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Geofencing Boundaries (Radius km)"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etGeofencing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Radius in km"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:backgroundTint="#888888"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSaveConfig"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Configuration"
        android:backgroundTint="#607D8B"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
