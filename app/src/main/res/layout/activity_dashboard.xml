<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/warm_cream"
    tools:context=".DashboardActivity">

    <!-- Header Section -->
    <ImageView
        android:id="@+id/dashAvatar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/img_avatar"
        android:scaleType="centerInside"
        android:background="@drawable/edit_text_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvWelcomeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Hello, User!"
        android:textColor="@color/soft_dark_gray"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toBottomOf="@+id/dashAvatar"
        app:layout_constraintStart_toEndOf="@+id/dashAvatar"
        app:layout_constraintTop_toTopOf="@+id/dashAvatar" />

    <!-- Search Bar -->
    <EditText
        android:id="@+id/dashSearch"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/edit_text_bg"
        android:hint="What are you looking for?"
        android:inputType="text"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:textColor="@color/soft_dark_gray"
        android:textColorHint="@color/text_hint_gray"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dashAvatar" />

    <TextView
        android:id="@+id/tvCategories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-medium"
        android:text="Categories"
        android:textColor="@color/soft_dark_gray"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dashSearch" />

    <!-- Categories Section -->
    <LinearLayout
        android:id="@+id/llCategories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:weightSum="3"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvCategories">

        <!-- Grocery -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnGrocery"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/edit_text_bg"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/img_grocery" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Grocery"
                android:textColor="@color/soft_dark_gray"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Food -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnFood"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/edit_text_bg"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/img_food" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Food"
                android:textColor="@color/soft_dark_gray"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Shop -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnShop"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/edit_text_bg"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/img_shop" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Shop"
                android:textColor="@color/soft_dark_gray"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
